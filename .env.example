# MindStory LMS — OpenAI 설정
# 사용법: 복사 → 루트에 `.env` 로 저장 후 값 입력. `.env` / `.dev.vars` 는 git 에 올리지 마세요.
# OpenAI 대시보드에서 프로젝트 이름(예: MindStory LMS2)으로 키를 관리해도 되며, 키 문자열은 오직 여기와 Cloudflare Secret 에만 둡니다.

OPENAI_API_KEY=

# 18행 부근: 공식 API 베이스 URL (프록시 없이 기본 엔드포인트)
OPENAI_BASE_URL=https://api.openai.com/v1

# 챗봇 모델 — 가성비와 응답 품질 균형 (권장)
OPENAI_MODEL=gpt-4o
