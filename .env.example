# MindStory LMS — OpenAI 설정
# 사용법: 복사 → 루트에 `.env` 로 저장 후 값 입력. `.env` / `.dev.vars` 는 git 에 올리지 마세요.
# OpenAI 대시보드에서 프로젝트 이름(예: MindStory LMS2)으로 키를 관리해도 되며, 키 문자열은 오직 여기와 Cloudflare Secret 에만 둡니다.

# ms12 — 카카오(콘솔 **ms12-official** app → JavaScript 키) — Vite 클라이언트에만. REST와는 별도
VITE_KAKAO_JS_KEY=
# ms12 — 카카오(콘솔 **ms12-rest-key** app → REST API 키) — .dev.vars / Cloudflare Secret `KAKAO_CLIENT_ID` 로만
# KAKAO_CLIENT_ID=

OPENAI_API_KEY=

# 18행 부근: 공식 API 베이스 URL (프록시 없이 기본 엔드포인트)
OPENAI_BASE_URL=https://api.openai.com/v1

# 챗봇 모델 — 가성비와 응답 품질 균형 (권장)
OPENAI_MODEL=gpt-4o

# Google OAuth (서버) — .dev.vars 에 넣을 때도 동일 키명. 콘솔 Authorized redirect: https://<호스트>/api/auth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# 로컬(선택): http://localhost:3000/api/auth/google/callback 과 동일한 URI를 Google Cloud Console 에 등록
# GOOGLE_REDIRECT_URI=
